{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)", "Bash(find *)",
      "Bash(mkdir *)", "Bash(mv *)", "Bash(cp *)",
      "Bash(npm *)", "Bash(npx *)",
      "Bash(python3 *)",
      "Bash(echo *)", "Bash(cat *)", "Bash(grep *)", "Bash(wc *)",
      "Bash(curl *)", "Bash(which *)",
      "Bash(cd *)", "Bash(pwd)", "Bash(date *)",
      "Bash(chmod *)", "Bash(touch *)",
      "Bash(gh *)",
      "Bash(uv run *)",
      "Bash(NODE_PATH=* node *)",
      "Bash(node *)",
      "Bash(soffice *)",
      "Bash(pdftoppm *)",
      "Bash(open *)",
      "Write(**/_inbox/subagents/**)",
      "Bash(bash *send_telegram.sh *)",
      "Bash(./*/send_telegram.sh *)",
      "Bash(*/send_telegram.sh *)",
      "Bash(bash *macwhisper_transcript.sh *)",
      "Bash(sqlite3 *MacWhisper*)"
    ],
    "ask": [
      "Edit(*)",
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git checkout -- *)",
      "Bash(rm *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/remind_subagent_rules.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check_deferred_actions.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/enforce_rule10.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/banned_phrases.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject_session_context.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
